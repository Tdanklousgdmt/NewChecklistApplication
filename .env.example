# ── Local mode (no Supabase server / no Edge / no /api) ──
# Build with VITE_LOCAL_MODE=true — auth + data live in localStorage only.
# Best for Vercel static deploy when backend keeps failing.
# VITE_LOCAL_MODE=true

# ── Normal mode: Supabase ──
# Leave VITE_LOCAL_MODE unset or false. Deploy Edge function + set SUPABASE_JWT_SECRET.
