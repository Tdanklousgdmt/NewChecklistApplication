# Supabase (required for auth + API)
# URL and anon key are in utils/supabase/info (or use Vite env if you migrate).

# JWT verification (must match Project Settings → API → JWT Secret):
# - Supabase Edge function secrets: SUPABASE_JWT_SECRET or APP_JWT_SECRET
# - Vercel serverless (/api): Vercel blocks *new* SUPABASE_* env names — use APP_JWT_SECRET

# Optional: absolute API base only (http/https). Relative /api is ignored; default is Supabase Edge.
# VITE_API_BASE_URL=https://your-project.supabase.co/functions/v1/make-server-d5ac9b81

# If you see 404 on /rest/v1/categories and /rest/v1/plant_users: either run
# supabase/migrations/001_create_categories_and_plant_users.sql in the SQL Editor,
# or set this to stop calling those tables (built-in checklist fallbacks are used).
# VITE_SKIP_DIRECT_DB_TABLES=true
